        "# ============================================================\n",
        "# 1. Install F5-TTS, Whisper and their dependencies\n",
        "# ============================================================\n",
        "# First, install ffmpeg which is required by Whisper\n",
        "!apt-get install -y ffmpeg\n",
        "\n",
        "# Upgrade pip and install the required packages\n",
        "!pip install --upgrade pip\n",
        "!pip install f5-tts openai-whisper torchaudio gradio\n",
        "\n",
        "import os\n",
        "import shutil\n",
        "import whisper\n",
        "import torch\n",
        "import gradio as gr\n",
        "from datetime import datetime\n",
        "from google.colab import drive\n",
        "\n",
        "# ============================================================\n",
        "# 2. Mount Google Drive\n",
        "# ============================================================\n",
        "# Mount your Google Drive to save voice models and generated audio\n",
        "drive.mount('/content/drive', force_remount=True)\n",
        "\n",
        "# Define folder paths\n",
        "BASE_DIR = \"/content/drive/MyDrive/F5-TTS\"                     # Root folder in Drive\n",
        "VOICE_MODELS_DIR = os.path.join(BASE_DIR, \"voice_models\")    # Folder to store uploaded voice samples\n",
        "OUTPUT_DIR = \"/content/tts_outputs\"                          # Local folder to store generated audio\n",
        "\n",
        "# Create the folders if they don't exist\n",
        "os.makedirs(VOICE_MODELS_DIR, exist_ok=True)\n",
        "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
        "\n",
        "# ============================================================\n",
        "# 3. Load the Whisper model\n",
        "# ============================================================\n",
        "# \"base\" model is a good balance of speed and accuracy for transcribing uploaded samples\n",
        "print(\"Loading Whisper model...\")\n",
        "stt_model = whisper.load_model(\"base\")\n",
        "\n",
        "# ============================================================\n",
        "# Helper Functions\n",
        "# ============================================================\n",
        "\n",
        "def get_saved_voices():\n",
        "    \"\"\"\n",
        "    Returns a list of audio files (names) present in the voice_models folder.\n",
        "    \"\"\"\n",
        "    if not os.path.exists(VOICE_MODELS_DIR):\n",
        "        return []\n",
        "    files = [f for f in os.listdir(VOICE_MODELS_DIR) if f.endswith(('.wav', '.mp3'))]\n",
        "    return sorted(files)\n",
        "\n",
        "def refresh_voice_list():\n",
        "    \"\"\"\n",
        "    Refreshes the voice selection dropdown list.\n",
        "    \"\"\"\n",
        "    new_choices = get_saved_voices()\n",
        "    return gr.Dropdown(choices=new_choices, value=new_choices[0] if new_choices else None)\n",
        "\n",
        "def save_new_voice(file_path, name):\n",
        "    \"\"\"\n",
        "    Saves the uploaded audio file, automatically transcribes it, and saves the transcript.\n",
        "    \"\"\"\n",
        "    if file_path is None or name.strip() == \"\":\n",
        "        return \"Error: Please upload a file and provide a name.\", \"\"\n",
        "    # Copy the uploaded file to the voice_models folder\n",
        "    target_path = os.path.join(VOICE_MODELS_DIR, f\"{name}.wav\")\n",
        "    shutil.copy(file_path, target_path)\n",
        "    # Transcribe the audio file\n",
        "    result = stt_model.transcribe(target_path)\n",
        "    transcript = result[\"text\"].strip()\n",
        "    # Save the transcript to a text file with the same name\n",
        "    with open(os.path.join(VOICE_MODELS_DIR, f\"{name}.txt\"), \"w\") as f:\n",
        "        f.write(transcript)\n",
        "    return f\"Voice '{name}' saved successfully!\", transcript\n",
        "\n",
        "def generate_tts(selected_voice, ref_text, gen_text):\n",
        "    \"\"\"\n",
        "    Generates TTS audio using the selected reference voice and text.\n",
        "    \"\"\"\n",
        "    # Validate inputs\n",
        "    if not selected_voice or not gen_text:\n",
        "        return None, \"Error: Please select a voice and enter the text to speak.\"\n",
        "\n",
        "    ref_audio_path = os.path.join(VOICE_MODELS_DIR, selected_voice)\n",
        "\n",
        "    # If the user hasn't provided a reference text, try to load the saved one\n",
        "    if not ref_text:\n",
        "        txt_path = os.path.join(VOICE_MODELS_DIR, selected_voice.rsplit('.', 1)[0] + \".txt\")\n",
        "        if os.path.exists(txt_path):\n",
        "            with open(txt_path, \"r\") as f:\n",
        "                ref_text = f.read()\n",
        "        else:\n",
        "            return None, \"Error: No transcript found. Please type the reference text manually.\"\n",
        "\n",
        "    # Create a unique name for the output file using a timestamp\n",
        "    timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n",
        "    output_filename = f\"tts_{timestamp}.wav\"\n",
        "    output_path = os.path.join(OUTPUT_DIR, output_filename)\n",
        "\n",
        "    # Run the F5-TTS CLI to generate the audio\n",
        "    # Corrected based on usage: --output_file instead of --output_name, and removed invalid positional argument\n",
        "    !python3 -m f5_tts.infer.infer_cli \\\n",
        "        --ref_audio \"{ref_audio_path}\" \\\n",
        "        --ref_text \"{ref_text}\" \\\n",
        "        --gen_text \"{gen_text}\" \\\n",
        "        --output_dir \"{OUTPUT_DIR}\" \\\n",
        "        --output_file \"{output_filename}\"\n",
        "\n",
        "    # Check if the file was created successfully\n",
        "    if os.path.exists(output_path):\n",
        "        return output_path, f\"Generated successfully as: {output_filename}\"\n",
        "    else:\n",
        "        return None, \"Error: TTS generation failed. Check the terminal output above for details.\"\n",
        "\n",
        "# ============================================================\n",
        "# 4. Gradio User Interface\n",
        "# ============================================================\n",
        "with gr.Blocks(title=\"F5-TTS Pro Manager\") as demo:\n",
        "    gr.Markdown(\"## 🎙️ F5-TTS Voice Cloning & TTS Generator\")\n",
        "\n",
        "    with gr.Tab(\"1. Generate Speech\"):\n",
        "        with gr.Row():\n",
        "            voice_dropdown = gr.Dropdown(\n",
        "                label=\"🎤 Select Voice\",\n",
        "                choices=get_saved_voices(),\n",
        "                interactive=True\n",
        "            )\n",
        "            refresh_btn = gr.Button(\"🔄 Refresh Voices\", variant=\"secondary\", scale=0)\n",
        "\n",
        "        ref_text_input = gr.Textbox(\n",
        "            label=\"📖 Reference Text (Auto-filled if empty)\",\n",
        "            placeholder=\"Leave blank to automatically use the saved transcript for the selected voice.\",\n",
        "            lines=2\n",
        "        )\n",
        "        input_text = gr.Textbox(\n",
        "            label=\"✍️ Text to Speak\",\n",
        "            placeholder=\"Enter the text you want the AI voice to say...\",\n",
        "            lines=6\n",
        "        )\n",
        "        gen_btn = gr.Button(\"🚀 Generate Audio\", variant=\"primary\")\n",
        "        out_audio = gr.Audio(label=\"🎧 Generated Audio\", type=\"filepath\")\n",
        "        status = gr.Label(label=\"✅ Status\")\n",
        "\n",
        "    with gr.Tab(\"2. Clone a New Voice\"):\n",
        "        gr.Markdown(\"Upload a clear audio sample (WAV or MP3) to clone a new voice.\")\n",
        "        gr.Markdown(\"The AI will automatically transcribe it and save the voice for future use.\")\n",
        "        new_audio = gr.Audio(label=\"📂 Upload Sample\", type=\"filepath\")\n",
        "        new_name = gr.Textbox(label=\"🏷️ Voice Name (No spaces)\", placeholder=\"e.g., john_doe\")\n",
        "        save_btn = gr.Button(\"💾 Save to Drive\")\n",
        "        save_out = gr.Textbox(label=\"Status\", interactive=False)\n",
        "        auto_transcript = gr.Textbox(label=\"🤖 AI-Generated Transcript\", interactive=False)\n",
        "\n",
        "    # Wire up the buttons to their respective functions\n",
        "    refresh_btn.click(fn=refresh_voice_list, inputs=None, outputs=voice_dropdown)\n",
        "    save_btn.click(fn=save_new_voice, inputs=[new_audio, new_name], outputs=[save_out, auto_transcript])\n",
        "    gen_btn.click(fn=generate_tts, inputs=[voice_dropdown, ref_text_input, input_text], outputs=[out_audio, status])\n",
        "\n",
        "# ============================================================\n",
        "# 5. Launch the App\n",
        "# ============================================================\n",
        "demo.launch(share=True, debug=True)"
      ]
    }
